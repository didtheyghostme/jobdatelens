{
  "manifest_version": 3,
  "name": "JobDateLens",
  "version": "0.1.0",
  "description": "Shows datePosted and validThrough from JobPosting JSON-LD on job posting pages.",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Scan this page with JobDateLens"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Command+Shift+E"
      }
    }
  }
}
