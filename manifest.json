{
  "manifest_version": 3,
  "name": "JobDateLens",
  "version": "1.2.0",
  "minimum_chrome_version": "102",
  "description": "Shows datePosted and validThrough from JobPosting JSON-LD on job posting pages.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://jobs.lever.co/*",
    "https://www.ycombinator.com/*",
    "https://jobs.ashbyhq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Scan this page with JobDateLens"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Command+Shift+E"
      }
    }
  }
}
